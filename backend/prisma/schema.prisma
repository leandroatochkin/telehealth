// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  engineType    = "binary"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique @db.VarChar(30)
  email     String   @unique
  password  String

  dni       String?  @unique
  name      String?
  surname   String?

  medicalLicense String? 

  isVerified Boolean @default(false)
  role       Role    @default(PATIENT)

  otp        String?
  otpExpires DateTime?

  resetPasswordOTP        String?
  resetPasswordOTPExpires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  availabilities Availability[]

  professionalAppointments Appointment[] @relation("ProfessionalAppointments")
  patientAppointments      Appointment[] @relation("PatientAppointments")

  prescriptionsWritten  Prescription[] @relation("DoctorPrescriptions")
  prescriptionsReceived Prescription[] @relation("PatientPrescriptions")

  patientHistory MedicalHistory? @relation("PatientHistory")
}

enum Role {
  PATIENT
  ADMIN
  PROFESSIONAL
}

enum AppointmentStatus {
  scheduled
  active
  completed
  cancelled
  no_show
}

model Appointment {
  id        String   @id @default(uuid())

  professionalId  String
  patientId String

  professional    User @relation("ProfessionalAppointments", fields: [professionalId], references: [id])
  patient   User @relation("PatientAppointments", fields: [patientId], references: [id])

  startTime DateTime
  endTime   DateTime

  status AppointmentStatus @default(scheduled)

  professionalJoinedAt  DateTime?
  patientJoinedAt DateTime?
  endedAt         DateTime?

  createdAt DateTime @default(now())

  @@index([professionalId, startTime])
  @@index([patientId, startTime])
}

model Availability {
  id        String   @id @default(uuid())
  professionalId  String

  professional    User     @relation(fields: [professionalId], references: [id])
  date            DateTime?
  dayOfWeek Int      // 0 (Sunday) - 6 (Saturday)

  startTime String   // "09:00"
  endTime   String   // "17:00"
  duration  Int @default(30)
  createdAt DateTime @default(now())

  @@index([professionalId, dayOfWeek])
}

model Prescription {
  id String @id @default(uuid())

  doctorId  String
  patientId String

  doctorNameSnapshot String
  patientNameSnapshot String

  doctor  User @relation("DoctorPrescriptions", fields: [doctorId], references: [id])
  patient User @relation("PatientPrescriptions", fields: [patientId], references: [id])

  items PrescriptionItem[]

  createdAt DateTime @default(now())

  @@index([doctorId])
  @@index([patientId])
}

model PrescriptionItem {
  id String @id @default(uuid())

  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])

  drugName        String
  genericName     String?
  concentration   String?
  form            String?
  presentation    String?

  quantity Int

  createdAt DateTime @default(now())

  @@index([prescriptionId])
}

model MedicalHistory {
  id        String   @id @default(uuid())
  patientId String   @unique
  patient   User     @relation("PatientHistory", fields: [patientId], references: [id])
  
  entries   HistoryEntry[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HistoryEntry {
  id               String   @id @default(uuid())
  medicalHistoryId String
  history          MedicalHistory @relation(fields: [medicalHistoryId], references: [id])
  
  doctorId         String
  doctorName       String   // Snapshot of doctor at time of entry
  
  date             DateTime @default(now())
  details          String   @db.Text
  diagnostics      String[] // Array of strings for multiple diagnostics
  
  createdAt        DateTime @default(now())
}